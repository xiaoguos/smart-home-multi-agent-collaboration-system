SERVICE_HOST=0.0.0.0
SERVICE_PORT=12100
LOG_LEVEL=INFO

# Point this to your custom gesture model.
YOLO_MODEL_PATH=./models/gesture.pt
YOLO_DEVICE=cpu
YOLO_CONFIDENCE=0.25
MAX_IMAGE_SIDE=960
MAX_IMAGE_BYTES=6291456

# Learning mode: no full retrain required, samples are stored locally.
LEARNING_ENABLED=true
GESTURE_DB_URL=sqlite:///./data/gesture_learning.db
SIMILARITY_THRESHOLD=0.82
MIN_SAMPLES_PER_LABEL=3
MAX_SAMPLES_PER_LABEL=200
