{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react"],
  "categories": {
    "correctness": "error"
  },
  "env": {
    "builtin": true,
    "browser": true
  },
  "settings": {
    "react": {
      "version": "18.3"
    }
  },
  "rules": {
    "unicorn/no-empty-file": "off",
    "react-hooks/exhaustive-deps": "warn"
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "src-tauri/**",
    "backend-python/**",
    "backend-cangjie/**"
  ]
}
